# HiveClaw Configuration
# Copy to .env and fill in your API keys

# LLM Providers (at least one required)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Ollama (local LLMs)
# OLLAMA_BASE_URL=http://localhost:11434

# Server
HIVECLAW_PORT=4070

# Agent workspace — where agents can read/write files
# Default: ~/.hiveclaw/workspace (auto-created on startup)
# HIVECLAW_WORKSPACE=~/.hiveclaw/workspace
