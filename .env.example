# HiveClaw Configuration
# Copy to .env and fill in your values

# ── LLM Providers (at least one required) ──────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Ollama (local LLMs)
# OLLAMA_BASE_URL=http://localhost:11434

# ── Server ─────────────────────────────────────────────────────────────────
HIVECLAW_PORT=4070

# Agent workspace — where agents can read/write files
# Default: ~/.hiveclaw/workspace (auto-created on startup)
# HIVECLAW_WORKSPACE=~/.hiveclaw/workspace

# ── Web Search (optional, pick one) ───────────────────────────────────────
# Without any key, web_search uses DuckDuckGo (free, no API key, limited).
# Priority: Brave > Serper > Tavily
#
# Brave Search — https://brave.com/search/api (free: 2,000 queries/month)
# BRAVE_API_KEY=BSA...
#
# Serper.dev — https://serper.dev (free: 2,500 queries/month, Google results)
# SERPER_API_KEY=...
#
# Tavily — https://tavily.com (free: 1,000 queries/month, AI-optimized)
# TAVILY_API_KEY=tvly-...

# ── Channel Adapters v2 (all optional) ────────────────────────────────────
# Each channel is configured via the Settings UI or API.
# These env vars are convenience shortcuts; the UI/API takes precedence.
#
# Telegram — get token from @BotFather
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
#
# Discord — create bot at discord.com/developers, enable Gateway intents
# DISCORD_BOT_TOKEN=MTI...
#
# Slack — create app at api.slack.com, enable Socket Mode
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...
# SLACK_APP_TOKEN=xapp-...  (required for Socket Mode)
#
# WhatsApp — uses Baileys (multi-device). No env vars needed.
# QR code is shown via GET /nodes/:id/qr or SSE during first connect.
# Auth state saved to: ~/.hiveclaw/whatsapp/<channelId>/

# ── Canvas (optional) ─────────────────────────────────────────────────────
# Directory for canvas HTML/assets served at /canvas/*
# Default: ~/.hiveclaw/canvas/
# HIVECLAW_CANVAS_DIR=~/.hiveclaw/canvas/

# ── Node Pairing (optional) ───────────────────────────────────────────────
# No server-side env vars required for node pairing.
# Paired nodes connect via WebSocket at /api/nodes/connect.
# Node client config is stored at ~/.hiveclaw-node/config.json on the device.
#
# To pair a device:
#   1. POST /nodes/generate-code → get 6-digit code
#   2. On the device: npx hiveclaw-node pair --gateway https://your-server:4070
#   3. Enter the code → device receives auth token
