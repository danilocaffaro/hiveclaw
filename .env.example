# HiveClaw Configuration
# Copy to .env and fill in your API keys

# LLM Providers (at least one required)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Ollama (local LLMs)
# OLLAMA_BASE_URL=http://localhost:11434

# Server
HIVECLAW_PORT=4070

# Agent workspace — where agents can read/write files
# Default: ~/.hiveclaw/workspace (auto-created on startup)
# HIVECLAW_WORKSPACE=~/.hiveclaw/workspace

# ── Web Search (optional) ──────────────────────────────────────────────────
# Without any key, web_search uses DuckDuckGo (free, no API key, limited).
# For better results, configure ONE of these (priority: Brave > Serper > Tavily):
#
# Brave Search — https://brave.com/search/api (free: 2,000 queries/month)
# BRAVE_API_KEY=BSA...
#
# Serper.dev — https://serper.dev (free: 2,500 queries/month, Google results)
# SERPER_API_KEY=...
#
# Tavily — https://tavily.com (free: 1,000 queries/month, AI-optimized)
# TAVILY_API_KEY=tvly-...
