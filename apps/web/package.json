{
  "name": "@hiveclaw/web",
  "version": "1.3.4",
  "private": true,
  "scripts": {
    "dev": "next dev --port 4080",
    "build": "next build && node -e \"const fs=require('fs');const ts=Date.now();const f='public/sw.js';let c=fs.readFileSync(f,'utf8');c=c.replace('v__BUILD_TS__','v'+ts);const d=fs.existsSync('out')?'out':'.next/static';fs.mkdirSync(d,{recursive:true});fs.writeFileSync(d+'/sw.js',c);console.log('SW stamped to',d+'/sw.js','with',ts)\"",
    "start": "next start --port 4080",
    "typecheck": "tsc --noEmit",
    "lint": "next lint"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hiveclaw/shared": "workspace:*",
    "@mui/material": "^7.3.9",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/dompurify": "^3.2.0",
    "dompurify": "^3.3.3",
    "next": "^15.2.0",
    "postcss": "^8.5.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.2.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "typescript": "^5.8.0"
  }
}
